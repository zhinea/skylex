[Unit]
Description=Skylex Database Agent
Documentation=https://github.com/zhinea/skylex
After=network-online.target skylex-server.service
Wants=network-online.target

[Service]
Type=simple
User=skylex
Group=skylex
LogsDirectory=skylex
ExecStart=/usr/local/bin/skylex-agent
Restart=always
RestartSec=5
LimitNOFILE=65536
TimeoutStopSec=15

# Bound the Go runtime's heap so the long-lived agent stays small. GOMEMLIMIT
# is a soft ceiling the GC keeps the heap near; GOGC=50 collects more eagerly
# than the default 100. The agent also applies these defaults in-process, so
# they hold even under a hand-written unit without these lines.
Environment=GOMEMLIMIT=64MiB
Environment=GOGC=50

ReadWritePaths=/var/lib/postgresql/data /var/log/skylex
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
NoNewPrivileges=true
CapabilityBoundingSet=CAP_CHOWN CAP_DAC_OVERRIDE CAP_FOWNER CAP_SETUID CAP_SETGID CAP_SYS_NICE CAP_SYS_RESOURCE
AmbientCapabilities=CAP_CHOWN CAP_DAC_OVERRIDE CAP_FOWNER CAP_SETUID CAP_SETGID CAP_SYS_NICE CAP_SYS_RESOURCE

MemoryHigh=2G
MemoryMax=4G
CPUQuota=400%

[Install]
WantedBy=multi-user.target
